---
import Layout from "../layouts/Layout.astro";
import SubNavbar from "../components/common/SubNavbar.astro";
---

<Layout
	title="About Us | Priventry"
	description="Corporate profile, vision, strategy, and real results from Priventry.ai."
>
	<SubNavbar backUrl="/#about" backText="Back to Home" />

	<main class="panels-container">
		<!-- Intro Description Panel -->
		<div class="description panel">
			<div class="panel-content">
				<h1 class="intro-title">
					<span class="type-target">Infrastructure that </span><span
						class="accent type-target">Unlocks Human Potential</span
					><span class="cursor">|</span>
				</h1>
				<p class="intro-desc intro-reveal">
					We build AI systems that enable enterprise teams to move
					fast without compromising control and compliance. Leading AI
					Software Factory & Digital Transformation Consultant for
					corporations, state-owned enterprises, and governments.
				</p>
				<div class="scroll-down intro-reveal">
					<div class="arrow"></div>
				</div>
			</div>
		</div>

		<!-- Panel 1: Our Vision -->
		<section class="panel vision-section">
			<div class="panel-inner split transition-item">
				<div class="panel-left">
					<h2 class="panel__number">01</h2>
					<div class="canvas-text">Vision</div>
				</div>
				<div class="panel-right">
					<span class="panel-sub">Mission & Core Values</span>
					<h3>
						Unlocking the Potential of <span class="accent"
							>Enterprise Teams</span
						>
					</h3>
					<div class="panel-body">
						<p>
							We unlock human potential from repetitive mechanical
							work. We build infrastructure that allows your
							company to operate faster, smarter, and more
							efficiently — placing artificial intelligence as a
							co-worker, not just a tool.
						</p>
						<div class="vision-pillars">
							<div class="pillar">
								<h4>Intelligent Automation</h4>
								<p>
									Taking over repetitive tasks with high
									precision, freeing teams to focus on
									strategic work.
								</p>
							</div>
							<div class="pillar">
								<h4>Enterprise Security</h4>
								<p>
									Closed infrastructure with enterprise
									encryption standards. Your data is
									completely under your control.
								</p>
							</div>
							<div class="pillar">
								<h4>Infinite Scalability</h4>
								<p>
									Designed to grow in line with your business
									scale — from pilot projects to national
									deployments.
								</p>
							</div>
							<div class="pillar">
								<h4>Seamless Integration</h4>
								<p>
									Direct connection with the existing
									ecosystem: ERP, HRIS, CRM, to Active
									Directory.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Panel 2: Our Strategy -->
		<section class="panel strategy-section">
			<div class="panel-inner split inverted transition-item">
				<div class="panel-right">
					<span class="panel-sub">Focus & Methodology</span>
					<h3>
						Metrics Felt <span class="accent">Directly</span>
					</h3>
					<div class="panel-body">
						<ul class="strategy-list">
							<li>
								<strong>01. Executive Audit & Scoping</strong>
								<span
									>Analyzing gaps in existing systems and
									identifying repetitive processes that can be
									automated.</span
								>
							</li>
							<li>
								<strong
									>02. Rapid Prototyping (2–4 Weeks)</strong
								>
								<span
									>Delivering the first functional modules so
									ROI can be validated before full commitment.</span
								>
							</li>
							<li>
								<strong>03. Integration & Go-Live</strong>
								<span
									>Connecting AI solutions to existing
									infrastructure (ERP, HRIS, APIs) with a full
									audit trail.</span
								>
							</li>
							<li>
								<strong>04. Monitoring & Scale-Up</strong>
								<span
									>Real-time AI performance monitoring with
									analytics dashboards and automated KPI
									reporting.</span
								>
							</li>
						</ul>
					</div>
				</div>
				<div class="panel-left">
					<h2 class="panel__number">02</h2>
					<div class="canvas-text">Strategy</div>
				</div>
			</div>
		</section>

		<!-- Panel 3: Our Result -->
		<section class="panel result-section">
			<div class="panel-inner split transition-item">
				<div class="panel-left">
					<h2 class="panel__number">03</h2>
					<div class="canvas-text">Result</div>
				</div>
				<div class="panel-right">
					<span class="panel-sub">Real Results from Our Clients</span>
					<h3>
						Measurable Results, <span class="accent"
							>Not Just Promises</span
						>
					</h3>
					<div class="panel-body">
						<p>
							Our success metrics are measured by the time and
							operational costs saved by our partners. Detailed
							calculations are available in each case study.
						</p>

						<div class="stats-grid">
							<div class="stat-item">
								<span class="stat-val">70%+</span>
								<span class="stat-label"
									>Manual Document Reduction</span
								>
							</div>
							<div class="stat-item">
								<span class="stat-val">95%</span>
								<span class="stat-label"
									>AI System Accuracy</span
								>
							</div>
							<div class="stat-item">
								<span class="stat-val">Days → Hours</span>
								<span class="stat-label">Approval Speed</span>
							</div>
							<div class="stat-item">
								<span class="stat-val">100%</span>
								<span class="stat-label"
									>Auto-Generated Reports</span
								>
							</div>
						</div>

						<div class="expanded-results">
							<div class="res-detail">
								<strong
									>Financial & Operational Efficiency</strong
								>
								<p>
									Transforming financial document approval
									processes from days to minutes — with a full
									audit trail that can be verified at any
									time.
								</p>
							</div>
							<div class="res-detail">
								<strong>Data Security & Governance</strong>
								<p>
									Faster decisions without compromising
									control. Seamless integration with existing
									enterprise systems, featuring industry-grade
									security standards.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Panel 4: Gallery -->
		<section class="panel gallery-panel">
			<div class="gallery transition-item">
				<div class="canvas-text gallery-bg-text">Gallery</div>
				<ul class="cards">
					<li
						style="background-image: url(https://images.unsplash.com/photo-1677442135703-1787eea5ce01?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1620712943543-bcc4688e7485?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1531482615713-2afd69097998?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
					<li
						style="background-image: url(https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=600&auto=format&fit=crop)"
					>
					</li>
				</ul>
				<div class="actions">
					<button
						class="gallery-btn prev"
						aria-label="Previous Slide"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path d="m15 18-6-6 6-6"></path></svg
						>
					</button>
					<button class="gallery-btn next" aria-label="Next Slide">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path d="m9 18 6-6-6-6"></path></svg
						>
					</button>
				</div>
			</div>
			<div class="drag-proxy"></div>
		</section>
	</main>
</Layout>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { Draggable } from "gsap/Draggable";
	import { TextPlugin } from "gsap/TextPlugin";

	gsap.registerPlugin(ScrollTrigger, Draggable, TextPlugin);

	// Normalize scroll to eliminate browser-native jitter ("grejet-grejet")
	if (window.innerWidth >= 1024) {
		ScrollTrigger.normalizeScroll(true);
	}
	ScrollTrigger.config({ ignoreMobileResize: true });

	function initAnimation() {
		const panelsContainer = document.querySelector(
			".panels-container",
		) as HTMLElement;
		if (!panelsContainer) return;

		const panels = gsap.utils.toArray(".panel") as HTMLElement[];
		if (panels.length === 0) return;

		const mm = gsap.matchMedia();

		// --- DESKTOP ANIMATIONS (PINNED SLIDES) ---
		mm.add("(min-width: 1024px)", () => {
			// 1. Initial State: Stack all panels
			gsap.set(panels, {
				position: "absolute",
				top: 0,
				left: 0,
				width: "100%",
				height: "100vh",
				autoAlpha: 0,
				zIndex: (i) => 10 + i,
			});

			gsap.set(panels[0], { autoAlpha: 1 });

			// 1.1 Intro Cinematic Animation Sequence
			const introTL = gsap.timeline(); // No delay

			// a. Munculkan "Corporate Profile" perlahan dari bawah
			introTL.from(".sub-heading.intro-reveal", {
				y: 10,
				opacity: 0,
				duration: 0.4,
				ease: "power3.out",
			});

			// b. Animasi Mengetik "The Standard of Excellence"
			const typeTargets = document.querySelectorAll(".type-target");
			const cursor = document.querySelector(".cursor");

			// Kursor berkedip
			gsap.to(cursor, {
				opacity: 0,
				repeat: -1,
				duration: 0.5,
				ease: "steps(1)",
			});

			typeTargets.forEach((target) => {
				const text = target.textContent || "";
				target.textContent = "";

				introTL.to(target, {
					text: text,
					duration: 0.4, // Lebih cepat mengetik
					ease: "none",
					onStart: () => {
						gsap.set(target, { visibility: "visible" });
					},
				});
			});

			// Sembunyikan kursor sesaat setelah selesai mengetik
			introTL.to(cursor, { opacity: 0, duration: 0.3 }, "+=0.5");

			// c. Munculkan deskripsi panjang dan panah scroll
			introTL.from(
				".intro-desc.intro-reveal, .scroll-down.intro-reveal",
				{
					y: 15,
					opacity: 0,
					duration: 0.5,
					stagger: 0.1,
					ease: "power3.out",
				},
				"-=0.1",
			);

			// 2. Master Timeline for Seamless Layering (Optimized Performance)
			const masterTL = gsap.timeline({
				scrollTrigger: {
					trigger: panelsContainer,
					start: "top top",
					end: `+=${(panels.length - 1) * 80}%`, // Jarak ideal agar tidak terlalu cepat tapi tidak ada jeda kosong
					pin: true,
					scrub: 1.2, // Angka ideal untuk kehalusan (smoothness) yang mewah
					anticipatePin: 1,
					fastScrollEnd: true,
					preventOverlaps: "master",
				},
			});

			// 3. Sequential Reveal with Content Isolation
			panels.forEach((panel, i) => {
				if (i === 0) return;

				// Buat animasi slide-up untuk panel saat ini
				masterTL.fromTo(
					panel,
					{ yPercent: 100, autoAlpha: 0 },
					{
						yPercent: 0,
						autoAlpha: 1,
						duration: 0.8, // Durasi disamakan agar seimbang
						ease: "power2.inOut",
					},
				);

				// Di saat yang BERSAMAAN ("<"), hilangkan panel sebelumnya.
				masterTL.to(
					panels[i - 1],
					{
						autoAlpha: 0,
						duration: 0.8, // Durasi disamakan agar seimbang
						ease: "power2.inOut",
					},
					"<",
				); // "<" artinya berjalan berbarengan dengan animasi di atasnya

				// Entrance for split content items
				const transitionItems = panel.querySelectorAll(
					".transition-item, .panel-inner.split > *",
				);
				if (transitionItems.length > 0) {
					masterTL.from(
						transitionItems,
						{
							y: 40,
							opacity: 0,
							filter: "blur(10px)",
							duration: 0.5,
							stagger: 0.1,
							ease: "power2.out",
						},
						"-=0.3",
					);
				}
			});

			// 6. Seamless Infinite Wrap Logic (Tuned for Global Footer)
			let isWrapping = false;
			const handleScrollWrap = () => {
				if (isWrapping) return;
				const scroll = window.scrollY;
				const maxScroll = ScrollTrigger.maxScroll(window);

				// Detect when user hits the very bottom of the global footer
				if (scroll > maxScroll - 15) {
					isWrapping = true;
					window.scrollTo({ top: 15 });
					setTimeout(() => (isWrapping = false), 200);
				} else if (scroll < 10) {
					isWrapping = true;
					window.scrollTo({ top: maxScroll - 20 });
					setTimeout(() => (isWrapping = false), 200);
				}
			};

			window.addEventListener("scroll", handleScrollWrap, { passive: true });

			return () => {
				window.removeEventListener("scroll", handleScrollWrap);
			};
		});

		// --- MOBILE/TABLET ANIMATIONS (NATURAL SCROLL) ---
		mm.add("(max-width: 1023px)", () => {
			// Reset styles for linear layout
			gsap.set(panels, {
				position: "relative",
				top: "auto",
				left: "auto",
				width: "100%",
				height: "auto",
				autoAlpha: 1,
				yPercent: 0,
				zIndex: "auto",
			});

			const typeTargets = document.querySelectorAll(".type-target");
			typeTargets.forEach((target) => {
				gsap.set(target, { visibility: "visible" });
			});

			const cursor = document.querySelector(".cursor");
			if (cursor) gsap.set(cursor, { display: "none" });

			// Simple reveal for each panel as it enters viewport
			panels.forEach((panel, i) => {
				const transitionItems = panel.querySelectorAll(
					".transition-item, .panel-inner.split > *",
				);
				if (transitionItems.length > 0) {
					gsap.from(transitionItems, {
						scrollTrigger: {
							trigger: panel,
							start: "top 80%",
							toggleActions: "play none none reverse",
						},
						y: 30,
						opacity: 0,
						duration: 0.6,
						stagger: 0.1,
						ease: "power2.out",
					});
				}
			});
		});

		// --- 4. 3D Gallery Static Interaction (Manual Only, Shared across viewports) ---
		const galleryItems = gsap.utils.toArray(".cards li");
		const spacing = 0.1;
		const animateFunc = (element: any) => {
			const tl = gsap.timeline();
			const isMobile = window.innerWidth < 768;
			const centerScale = isMobile ? 1.05 : 1.15;
			const xDistance = isMobile ? 180 : 250;

			tl.fromTo(
				element,
				{ scale: 0, opacity: 0 },
				{
					scale: centerScale,
					opacity: 1,
					zIndex: 100,
					duration: 0.5,
					yoyo: true,
					repeat: 1,
					ease: "power1.in",
					immediateRender: false,
				},
			).fromTo(
				element,
				{ xPercent: xDistance },
				{
					xPercent: -xDistance,
					duration: 1,
					ease: "none",
					immediateRender: false,
				},
				0,
			);
			return tl;
		};

		const seamlessLoop = buildSeamlessLoop(
			galleryItems,
			spacing,
			animateFunc,
		);
		const playhead = { offset: 0 };
		const wrapTime = gsap.utils.wrap(0, seamlessLoop.duration());

		const updateGallery = (offset: number) => {
			gsap.to(playhead, {
				offset: offset,
				duration: 0.8,
				ease: "power3.out",
				onUpdate: () => {
					seamlessLoop.time(wrapTime(playhead.offset));
				},
			});
		};

		const nextBtn = document.querySelector(".next");
		const prevBtn = document.querySelector(".prev");

		nextBtn?.addEventListener("click", () =>
			updateGallery(playhead.offset + spacing),
		);
		prevBtn?.addEventListener("click", () =>
			updateGallery(playhead.offset - spacing),
		);

		Draggable.create(".drag-proxy", {
			type: "x",
			trigger: ".cards",
			onPress() {
				this.startOffset = playhead.offset;
			},
			onDrag() {
				playhead.offset =
					this.startOffset + (this.startX - this.x) * 0.001;
				seamlessLoop.time(wrapTime(playhead.offset));
			},
		});

		function buildSeamlessLoop(
			items: any[],
			spacing: number,
			animateFunc: Function,
		) {
			let overlap = Math.ceil(1 / spacing),
				startTime = items.length * spacing + 0.5,
				loopTime = (items.length + overlap) * spacing + 1,
				rawSequence = gsap.timeline({ paused: true }),
				seamlessLoop = gsap.timeline({
					paused: true,
					repeat: -1,
					onRepeat() {
						this._time === this._dur &&
							(this._tTime += this._dur - 0.01);
					},
				}),
				l = items.length + overlap * 2,
				time,
				i,
				index;

			for (i = 0; i < l; i++) {
				index = i % items.length;
				time = i * spacing;
				rawSequence.add(animateFunc(items[index]), time);
			}

			rawSequence.time(startTime);
			seamlessLoop
				.to(rawSequence, {
					time: loopTime,
					duration: loopTime - startTime,
					ease: "none",
				})
				.fromTo(
					rawSequence,
					{ time: overlap * spacing + 1 },
					{
						time: startTime,
						duration: startTime - (overlap * spacing + 1),
						immediateRender: false,
						ease: "none",
					},
				);
			return seamlessLoop;
		}

		// 5. Shared UI Interactions
		document.getElementById("returnTop")?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		// Shared UI Interactions
		document.getElementById("returnTop")?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		// Scroll wrap logic moved inside desktop media query

		// Refresh ScrollTrigger after intro animation & layout settling
		setTimeout(() => {
			ScrollTrigger.refresh();
		}, 1500);
	}

	if (
		document.readyState === "complete" ||
		document.readyState === "interactive"
	) {
		initAnimation();
	} else {
		window.addEventListener("load", initAnimation);
	}
</script>

<style>
	/* Intro Description Specifics */
	.description .panel-content {
		text-align: center;
		max-width: 1100px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.intro-title {
		font-size: clamp(2.2rem, 5vw, 4rem);
		line-height: 1.1;
		margin-bottom: 0.8rem;
		font-weight: 800;
	}

	.intro-desc {
		font-size: clamp(1.2rem, 2.5vw, 1.8rem);
		max-width: 900px;
		line-height: 1.6;
		opacity: 0.8;
	}

	.cursor {
		font-weight: 100;
		color: var(--primary);
		margin-left: 2px;
	}

	.type-target {
		visibility: hidden;
	}

	.panels-container {
		width: 100%;
		background: var(--bg);
		position: relative;
		min-height: 100vh;
	}

	.panel {
		height: 100vh;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		position: absolute;
		top: 0;
		left: 0;
		overflow: hidden;
		padding: var(--nav-height) 5vw 2rem 5vw;
		background: var(--bg);
		opacity: 0;
		visibility: hidden;
		z-index: 1;
		will-change: transform, opacity;
		box-sizing: border-box;
	}

	/* Ensure first panel is visible on load, but allow GSAP to override it */
	.panel:first-child {
		opacity: 1;
		visibility: visible;
		z-index: 10;
	}

	/* Premium Split Layout Refined */
	.panel-inner.split {
		display: grid;
		grid-template-columns: 0.6fr 1.4fr;
		align-items: safe center;
		gap: 6vw;
		width: 90%;
		max-width: 1600px;
		max-height: 100%;
		position: relative;
		z-index: 2;
	}

	.panel-inner.inverted {
		grid-template-columns: 1.4fr 0.6fr;
	}

	.panel-left {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.panel-right {
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		text-align: left;
		max-height: 100%;
		overflow-y: auto;
		scrollbar-width: none;
		-ms-overflow-style: none;
		padding-right: 0.5rem;
	}

	.panel-right::-webkit-scrollbar {
		display: none;
	}

	.canvas-text {
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 800;
		color: var(--primary);
		opacity: 0.9;
		margin-top: -3rem;
		margin-left: 2rem;
		text-transform: uppercase;
		letter-spacing: 15px;
		user-select: none;
		position: relative;
		z-index: 2;
	}

	.panel-sub {
		display: inline-block;
		text-transform: uppercase;
		letter-spacing: 4px;
		font-size: 0.75rem;
		color: var(--bg);
