---
import Layout from "../layouts/Layout.astro";
import SubNavbar from "../components/common/SubNavbar.astro";

import { services } from "../data/services";
import { ArrowRight } from "lucide-astro";

// Pull representative images for the bento gallery
const bentoImages = [
	services[0].gallery[0],
	services[1].gallery[1],
	services[2].gallery[2],
	services[3].gallery[3],
	services[0].gallery[4],
	services[1].gallery[2],
	services[2].gallery[1],
	services[3].gallery[4],
];
---

<Layout
	title="Capabilities | Priventry"
	description="Custom technology solutions, artificial intelligence (AI), large-scale exam platforms, and blockchain systems for enterprise-scale businesses."
>
	<SubNavbar backUrl="/" backText="Back to Home" />

	<main class="services-page">
		<!-- Cinematic Intro Section -->
		<section class="services-hero">
			<div class="container hero-container">
				<span class="sub-heading intro-reveal">Our Expertise</span>
				<h1 class="page-title intro-title">
					<span class="type-target">Intelligent </span>
					<span class="accent type-target">Solutions</span>
				</h1>
				<p class="page-desc intro-reveal">
					Leading AI software factory and digital transformation consultant delivering real and sustainable impact for enterprises.
				</p>
			</div>
		</section>

		<!-- Bento Flip Gallery Section -->
		<section class="gallery-section">
			<div class="gallery-wrap">
				<div
					class="gallery gallery--bento gallery--switch"
					id="master-gallery"
				>
					{
						bentoImages.map((imgUrl, i) => (
							<div class="gallery__item">
								<img
									src={imgUrl}
									alt={`Showcase ${i + 1}`}
									loading="lazy"
								/>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Detailed Offerings Section (Shader Scroll) -->
		<section class="services-shader-section" id="shader-container">
			<div class="container narrow-container">
				<div class="section-header reveal-in">
					<h2 class="section-title">
						Focus <span class="accent">Areas</span>
					</h2>
					<p class="section-intro">
						Advanced services and platforms custom-designed to support data sovereignty and operational efficiency of your organization.
					</p>
				</div>
			</div>

			<div class="shader-stack">
				{
					services.map((service) => (
						<div
							class="service-frame"
							data-img={service.gallery[0]}
							style={`background-image: url(${service.gallery[0]})`}
						>
							<div class="frame-content">
								<div class="frame-glass">
									<div class="frame-txt">
										<h3>{service.title}</h3>
										<p>{service.shortDesc}</p>
										<div class="frame-tags">
											{service.features
												.slice(0, 3)
												.map((f) => (
													<span class="tag">{f}</span>
												))}
										</div>
										<a
											href={`/services/${service.slug}`}
											class="frame-btn"
										>
											Learn More <ArrowRight size={18} />
										</a>
									</div>
								</div>
							</div>
						</div>
					))
				}
			</div>
		</section>
	</main>


</Layout>

<style>
	.services-page {
		padding-top: var(--nav-height);
		background-color: var(--bg);
	}

	/* Hero */
	.services-hero {
		padding: 200px 0 60px;
		text-align: center;
		background: linear-gradient(to bottom, #04060a 0%, var(--bg) 100%);
	}

	.hero-container {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.sub-heading {
		display: block;
		text-transform: uppercase;
		letter-spacing: 5px;
		font-size: 0.85rem;
		color: var(--primary);
		margin-bottom: 2rem;
		font-weight: 600;
		font-family: var(--font-accent);
	}

	.page-title {
		font-size: clamp(3.5rem, 8vw, 7rem);
		color: var(--text);
		margin-bottom: 2rem;
		font-weight: 800;
		line-height: 1.1;
	}

	.page-title .accent {
		color: var(--primary);
	}

	.page-desc {
		font-size: clamp(1.1rem, 2vw, 1.3rem);
		color: var(--text-muted);
		max-width: 800px;
		line-height: 1.7;
	}

	/* Bento Gallery */
	.gallery-section {
		position: relative;
		width: 100%;
	}

	.gallery-wrap {
		position: relative;
		width: 100%;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.gallery {
		position: relative;
		width: 100%;
		height: 100%;
		flex: none;
	}

	.gallery__item {
		background-position: 50% 50%;
		background-size: cover;
		flex: none;
		position: relative;
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);

		img {
			object-fit: cover;
			width: 100%;
			height: 100%;
			transition: transform 0.8s ease;
		}
	}

	.gallery--bento {
		display: grid;
		gap: 1.5vh;
		grid-template-columns: repeat(3, 30vw);
		grid-template-rows: repeat(4, 20vh);
		justify-content: center;
		align-content: center;
	}

	.gallery--final.gallery--bento {
		grid-template-columns: repeat(3, 100vw);
		grid-template-rows: repeat(4, 50vh);
		gap: 0;
	}

	.gallery--bento .gallery__item:nth-child(1) {
		grid-area: 1 / 1 / 3 / 2;
	}
	.gallery--bento .gallery__item:nth-child(2) {
		grid-area: 1 / 2 / 2 / 3;
	}
	.gallery--bento .gallery__item:nth-child(3) {
		grid-area: 2 / 2 / 4 / 3;
	}
	.gallery--bento .gallery__item:nth-child(4) {
		grid-area: 1 / 3 / 3 / 3;
	}
	.gallery--bento .gallery__item:nth-child(5) {
		grid-area: 3 / 1 / 3 / 2;
	}
	.gallery--bento .gallery__item:nth-child(6) {
		grid-area: 3 / 3 / 5 / 4;
	}
	.gallery--bento .gallery__item:nth-child(7) {
		grid-area: 4 / 1 / 5 / 2;
	}
	.gallery--bento .gallery__item:nth-child(8) {
		grid-area: 4 / 2 / 5 / 3;
	}

	/* Shader Stack Section */
	.services-shader-section {
		padding: 120px 0;
		background-color: var(--bg);
	}

	.narrow-container {
		max-width: 1200px;
	}

	.section-header {
		text-align: center;
		margin-bottom: 8rem;
	}

	.shader-stack {
		display: flex;
		flex-direction: column;
		gap: clamp(3rem, 8vh, 6rem);
		padding-bottom: 15vh;
	}

	.service-frame {
		position: relative;
		width: 70vw;
		max-width: 700px;
		height: clamp(400px, 45vh, 480px);
		margin: 0 auto;
		border-radius: 24px;
		background: #080808;
		background-size: cover;
		background-position: center;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.03);
	}

	/* Each frame contains its own GL canvas */
	.service-frame canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
		opacity: 0.8;
	}

	.frame-content {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 5%;
		z-index: 2;
	}

	.frame-glass {
		background: rgba(10, 10, 10, 0.4);
		backdrop-filter: blur(20px);
		border: 1px solid rgba(255, 255, 255, 0.05);
		padding: 1.5rem;
		border-radius: 16px;
		max-width: 350px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 8px;
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
	}

	.frame-txt h3 {
		font-size: clamp(1.2rem, 1.8vw, 1.5rem);
		margin-top: 5px;
		margin-bottom: 5px;
		font-weight: 700;
	}

	.frame-txt p {
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.45;
		margin-bottom: 8px;
	}

	.frame-tags {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 5px;
		margin-bottom: 10px;
	}

	.tag {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 4px 8px;
		border-radius: 100px;
		color: var(--text-muted);
		width: fit-content;
	}

	.frame-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		font-size: 0.75rem;
		text-decoration: none;
		transition: transform 0.3s ease;
		margin-top: 5px;
	}

	.frame-btn:hover {
		transform: scale(1.05);
	}

	@media (max-width: 1024px) {
		.gallery-wrap {
			height: auto !important;
			padding: 4rem 5vw !important;
		}
		.gallery--bento {
			display: grid !important;
			grid-template-columns: repeat(2, 1fr) !important;
			grid-template-rows: auto !important;
			gap: 1.5rem !important;
			width: 100% !important;
		}
		.gallery--bento .gallery__item {
			grid-area: auto !important;
			height: 250px !important;
		}
	}

	@media (max-width: 768px) {
		.services-hero {
			padding: 120px 0 40px !important;
		}
		.services-shader-section {
			padding: 60px 0 !important;
		}
		.section-header {
			margin-bottom: 3rem !important;
		}
		.gallery-wrap {
			padding: 2rem 5vw !important;
		}
		.gallery--bento {
			grid-template-columns: 1fr !important;
			gap: 1rem !important;
		}
		.gallery--bento .gallery__item {
			height: 200px !important;
		}
		.service-frame {
			height: auto;
			width: 90vw;
		}
		.frame-content {
			position: relative;
			inset: auto;
			padding: 1.5rem 1rem;
			display: flex;
			align-items: stretch;
			justify-content: stretch;
			z-index: 2;
		}
		.frame-glass {
			max-width: 100%;
			width: 100%;
			padding: 1.2rem;
			margin-top: 0;
		}
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { Flip } from "gsap/Flip";
	import * as THREE from "three";

	gsap.registerPlugin(ScrollTrigger, Flip);

	function initServicesPage() {
		const mm = gsap.matchMedia();

		// --- DESKTOP ANIMATIONS ---
		mm.add("(min-width: 1024px)", () => {
			// 1. Entrance Reveals
			gsap.from(".intro-reveal", {
				y: 30,
				opacity: 0,
				duration: 1,
				stagger: 0.2,
				ease: "power3.out",
			});

			// 2. Bento Flip Logic
			const galleryElement = document.querySelector("#master-gallery");
			if (galleryElement) {
				const galleryItems =
					galleryElement.querySelectorAll(".gallery__item");
				const galleryWrap = galleryElement.closest(".gallery-wrap");

				// Capture final state
				galleryElement.classList.add("gallery--final");
				const flipState = Flip.getState(galleryItems);
				galleryElement.classList.remove("gallery--final");

				const tl = gsap.timeline({
					scrollTrigger: {
						trigger: galleryWrap,
						start: "center center",
						end: "+=120%",
						scrub: 1,
						pin: true,
						anticipatePin: 1,
					},
				});
				tl.add(
					Flip.from(flipState, { simple: true, ease: "power2.inOut" }),
				);
			}

			// 3. Global Shader Velocity State & Three.js Canvas
			const velocityProxy = { v: 0, s: 0 };
			const clamp = gsap.utils.clamp(-2000, 2000);

			ScrollTrigger.create({
				start: 0,
				end: () =>
					document.documentElement.scrollHeight - window.innerHeight,
				onUpdate(self) {
					const raw = clamp(self.getVelocity());
					const norm = raw / 1000;
					const strength = Math.min(1, Math.abs(norm));

					if (Math.abs(strength) > Math.abs(velocityProxy.s)) {
						velocityProxy.v = norm;
						velocityProxy.s = strength;
						gsap.to(velocityProxy, {
							v: 0,
							s: 0,
							duration: 0.8,
							ease: "sine.inOut",
							overwrite: true,
						});
					}
				},
			});

			const vert = `
				varying vec2 vUv;
				varying vec2 vUvCover;
				uniform vec2 uTextureSize;
				uniform vec2 uQuadSize;

				void main(){
					vUv = uv;
					float texR = uTextureSize.x / uTextureSize.y;
					float quadR = uQuadSize.x / uQuadSize.y;
					vec2 s = vec2(1.0);
					if (quadR > texR) { s.y = texR / quadR; } else { s.x = quadR / texR; }
					vUvCover = vUv * s + (1.0 - s) * 0.5;
					gl_Position = vec4(position, 1);
				}
			`;

			const frag = `
				precision highp float;
				uniform sampler2D uTexture;
				uniform float uTime;
				uniform float uScrollVelocity;
				uniform float uVelocityStrength;
				varying vec2 vUvCover;

				void main() {
					vec2 texCoords = vUvCover;
					float amt = 0.05 * uVelocityStrength;
					float t = uTime * 0.8;
					texCoords.y += sin((texCoords.x * 8.0) + t) * amt;
					texCoords.x += cos((texCoords.y * 6.0) - t * 0.8) * amt * 0.6;
					float dir = sign(uScrollVelocity);
					float r = texture2D(uTexture, texCoords + vec2(amt * 0.50 * dir, 0.0)).r;
					float g = texture2D(uTexture, texCoords + vec2(amt * 0.25 * dir, 0.0)).g;
					float b = texture2D(uTexture, texCoords + vec2(-amt * 0.35 * dir, 0.0)).b;
					gl_FragColor = vec4(r, g, b, 1.0);
				}
			`;

			const frames = document.querySelectorAll(".service-frame");

			const observerOptions = {
				root: null,
				rootMargin: "200px",
				threshold: 0,
			};

			const observer = new IntersectionObserver((entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						initFrame(entry.target as HTMLElement);
						obs.unobserve(entry.target);
					}
				});
			}, observerOptions);

			frames.forEach((frame) => observer.observe(frame));

			function initFrame(frameEl: HTMLElement) {
				const renderer = new THREE.WebGLRenderer({
					antialias: true,
					alpha: true,
				});
				frameEl.appendChild(renderer.domElement);
				renderer.outputColorSpace = THREE.SRGBColorSpace;
				renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));

				const scene = new THREE.Scene();
				const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
				const geom = new THREE.PlaneGeometry(2, 2);

				const uniforms = {
					uTexture: { value: null as THREE.Texture | null },
					uTextureSize: { value: new THREE.Vector2(1, 1) },
					uQuadSize: { value: new THREE.Vector2(1, 1) },
					uTime: { value: 0 },
					uScrollVelocity: { value: 0 },
					uVelocityStrength: { value: 0 },
				};

				const mat = new THREE.ShaderMaterial({
					uniforms,
					vertexShader: vert,
					fragmentShader: frag,
					transparent: true,
				});

				const mesh = new THREE.Mesh(geom, mat);
				scene.add(mesh);

				const url = frameEl.getAttribute("data-img") || "";
				const loader = new THREE.TextureLoader();
				const optimizedUrl = url.includes("unsplash.com")
					? `${url}&w=1200&q=80`
					: url;

				loader.load(optimizedUrl, (tex) => {
					tex.colorSpace = THREE.SRGBColorSpace;
					uniforms.uTexture.value = tex;
					uniforms.uTextureSize.value.set(
						tex.image.width,
						tex.image.height,
					);
					layout();
					gsap.to(renderer.domElement, { opacity: 1, duration: 0.8 });
				});

				function layout() {
					const { width, height } = frameEl.getBoundingClientRect();
					renderer.setSize(width, height, false);
					uniforms.uQuadSize.value.set(width, height);
				}

				let last = performance.now();
				let frameId: number;
				function tick(now: number) {
					const dt = (now - last) * 0.001;
					last = now;
					uniforms.uTime.value += dt;
					uniforms.uScrollVelocity.value = velocityProxy.v;
					uniforms.uVelocityStrength.value = velocityProxy.s;
					renderer.render(scene, camera);
					frameId = requestAnimationFrame(tick);
				}
				frameId = requestAnimationFrame(tick);

				window.addEventListener("resize", layout);

				gsap.from(frameEl.querySelector(".frame-glass"), {
					scrollTrigger: {
						trigger: frameEl,
						start: "top 80%",
						toggleActions: "play none none reverse",
					},
					y: 50,
					opacity: 0,
					duration: 1,
					ease: "power2.out",
				});
			}
		});

		// --- MOBILE/TABLET ANIMATIONS ---
		mm.add("(max-width: 1023px)", () => {
			// 1. Entrance Reveals
			gsap.from(".intro-reveal", {
				y: 20,
				opacity: 0,
				duration: 0.8,
				stagger: 0.15,
				ease: "power3.out",
			});

			// 2. Simple Scroll Trigger for bento items on mobile
			const galleryItems = document.querySelectorAll(".gallery__item");
			if (galleryItems.length > 0) {
				gsap.from(galleryItems, {
					scrollTrigger: {
						trigger: "#master-gallery",
						start: "top 85%",
						toggleActions: "play none none reverse",
					},
					scale: 0.9,
					opacity: 0,
					duration: 0.8,
					stagger: 0.1,
					ease: "power2.out",
				});
			}

			// 3. Simple Scroll Trigger for service frames on mobile
			const frames = document.querySelectorAll(".service-frame");
			frames.forEach((frame) => {
				gsap.from(frame.querySelector(".frame-glass"), {
					scrollTrigger: {
						trigger: frame,
						start: "top 85%",
						toggleActions: "play none none reverse",
					},
					y: 30,
					opacity: 0,
					duration: 0.8,
					ease: "power2.out",
				});
			});
		});
	}

	function runAfterPreloader(initFunc: () => void) {
		let initialized = false;
		const triggerInit = () => {
			if (initialized) return;
			initialized = true;
			initFunc();
		};

		if (sessionStorage.getItem("compro_visited") === "true") {
			if (
				document.readyState === "complete" ||
				document.readyState === "interactive"
			) {
				setTimeout(triggerInit, 100);
			} else {
				window.addEventListener("load", triggerInit);
			}
		} else {
			window.addEventListener("preloaderComplete", triggerInit);
			setTimeout(triggerInit, 4000);
		}
	}

	runAfterPreloader(initServicesPage);
</script>
