---
import Layout from "../../layouts/Layout.astro";
import SubNavbar from "../../components/common/SubNavbar.astro";

import { services } from "../../data/services";
import { ArrowLeft, CheckCircle2 } from "lucide-astro";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={`${service.title} | Priventry`} description={service.shortDesc}>
  <SubNavbar backUrl="/services" backText="Back to Capabilities" />

  <main class="service-detail">
    <section class="detail-hero">
      <div class="container hero-container">
        <div class="hero-content">
          <h1 class="reveal-in">{service.title}</h1>
          <p class="lead reveal-in">{service.fullDesc}</p>
        </div>
      </div>
    </section>

    <!-- The Deep Dive Section -->
    <section class="deep-dive section">
      <div class="container narrow-container reveal-in">
        <h2 class="accent-title">In-Depth Analysis</h2>
        <div class="long-desc">
          <p>{service.longDesc}</p>
        </div>
      </div>
    </section>

    <!-- Premium Bento Gallery Section (GSAP Flip) -->
    <section class="gallery-section">
      <div class="gallery-wrap">
        <div
          class="gallery gallery--bento gallery--switch"
          id="service-gallery"
        >
          {
            service.gallery.map((imgUrl) => (
              <div class="gallery__item">
                <img
                  src={imgUrl}
                  alt={`${service.title} showcase`}
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Methodology Section -->
    <section class="methodology section">
      <div class="container wider-container">
        <div class="section-header reveal-in">
          <h2 class="accent-title">Working Methodology</h2>
          <p>Structured and proven approach to deliver reliable IT integration.</p>
        </div>

        <div class="process-grid">
          {
            service.process.map((p) => (
              <div class="process-step reveal-in">
                <span class="step-num">{p.step}</span>
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Key Features & Benefits (Revised Layout) -->
    <section class="detail-content section">
      <div class="container wider-container">
        <div class="content-grid">
          <div class="content-section reveal-in">
            <h2 class="accent-title">Key Capabilities</h2>
            <ul class="feature-list">
              {
                service.features.map((feature) => (
                  <li>
                    <CheckCircle2 class="icon" size={24} />
                    <span>{feature}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="content-section reveal-in">
            <h2 class="accent-title">Business Impact</h2>
            <div class="benefits-grid">
              {
                service.benefits.map((benefit) => (
                  <div class="benefit-card">
                    <p>{benefit}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technology Stack Section -->
    <section class="tech-stack section reveal-in">
      <div class="container">
        <h2 class="tech-title">Technologies Used</h2>
        <div class="tech-tags">
          {
            service.techStack.map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .service-detail {
    padding-top: var(--nav-height);
    background: var(--bg);
  }

  .detail-hero {
    padding: 220px 0 100px;
    background: linear-gradient(to bottom, #04060a 0%, var(--bg) 100%);
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  h1 {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    margin-bottom: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .lead {
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    color: var(--text-muted);
    max-width: 900px;
    line-height: 1.7;
    margin: 0 auto;
    text-align: center;
  }

  /* Deep Dive */
  .deep-dive {
    padding: 80px 0;
  }

  .narrow-container {
    max-width: 900px;
  }

  .long-desc p {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.8;
    color: var(--text);
    opacity: 0.9;
  }

  /* Bento Gallery Section */
  .gallery-section {
    position: relative;
    width: 100%;
    margin: 100px 0;
  }

  .gallery-wrap {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .gallery {
    position: relative;
    width: 100%;
    height: 100%;
    flex: none;
  }

  .gallery__item {
    background-position: 50% 50%;
    background-size: cover;
    flex: none;
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);

    img {
      object-fit: cover;
      width: 100%;
      height: 100%;
    }
  }

  .gallery--bento {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(4, 250px);
    width: 90%;
    margin: 0 auto;
  }

  .gallery--final.gallery--bento {
    grid-template-columns: repeat(3, 100vw);
    grid-template-rows: repeat(4, 50vh);
    gap: 0;
  }

  .gallery--bento .gallery__item:nth-child(1) {
    grid-area: 1 / 1 / 3 / 2;
  }
  .gallery--bento .gallery__item:nth-child(2) {
    grid-area: 1 / 2 / 2 / 3;
  }
  .gallery--bento .gallery__item:nth-child(3) {
    grid-area: 2 / 2 / 4 / 3;
  }
  .gallery--bento .gallery__item:nth-child(4) {
    grid-area: 1 / 3 / 3 / 3;
  }
  .gallery--bento .gallery__item:nth-child(5) {
    grid-area: 3 / 1 / 3 / 2;
  }
  .gallery--bento .gallery__item:nth-child(6) {
    grid-area: 3 / 3 / 5 / 4;
  }
  .gallery--bento .gallery__item:nth-child(7) {
    grid-area: 4 / 1 / 5 / 2;
  }
  .gallery--bento .gallery__item:nth-child(8) {
    grid-area: 4 / 2 / 5 / 3;
  }

  @media (max-width: 1024px) {
    .gallery-section {
      margin: 40px 0 !important;
    }
    .gallery-wrap {
      height: auto !important;
      padding: 4rem 5vw !important;
    }
    .gallery {
      height: auto !important;
    }
    .gallery--bento {
      grid-template-columns: repeat(2, 1fr) !important;
      grid-template-rows: auto !important;
      gap: 1rem !important;
      width: 100% !important;
    }
    /* Simple reset for items on mobile to avoid complex area assignments */
    .gallery--bento .gallery__item {
      grid-area: auto !important;
      height: 250px !important;
      aspect-ratio: auto !important;
    }
  }

  @media (max-width: 768px) {
    .gallery-wrap {
      padding: 2rem 5vw !important;
    }
    .gallery--bento {
      grid-template-columns: 1fr !important;
    }
    .gallery--bento .gallery__item {
      height: 200px !important;
    }
  }

  /* Methodology */
  .methodology {
    padding: 120px 0;
    background: rgba(255, 255, 255, 0.01);
  }

  .section-header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .section-header p {
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .process-step {
    position: relative;
    padding: 3rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(252, 159, 33, 0.05);
    border-radius: 24px;
    transition: all 0.4s ease;
  }

  .process-step:hover {
    border-color: var(--primary);
    transform: translateY(-10px);
  }

  .step-num {
    display: block;
    font-size: 3rem;
    font-weight: 900;
    color: rgba(252, 159, 33, 0.1);
    margin-bottom: 1rem;
    line-height: 1;
    font-family: var(--font-accent);
  }

  .process-step h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .process-step p {
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Revised Content Section */
  .detail-content {
    padding: 120px 0;
  }

  .wider-container {
    max-width: 1400px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
  }

  .accent-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 3rem;
    color: var(--primary);
    font-family: var(--font-accent);
    font-weight: 600;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    font-size: 1.25rem;
  }

  .feature-list .icon {
    color: var(--primary);
    flex-shrink: 0;
    margin-top: 5px;
  }

  .benefits-grid {
    display: grid;
    gap: 2.5rem;
  }

  .benefit-card {
    padding: 3rem;
    background-color: var(--surface);
    border-radius: 24px;
    border: 1px solid rgba(252, 159, 33, 0.05);
  }

  .benefit-card p {
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.6;
  }

  /* Tech Stack */
  .tech-stack {
    padding: 100px 0 150px;
    text-align: center;
  }

  .tech-title {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .tech-tag {
    padding: 12px 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    font-weight: 600;
    color: var(--primary);
    transition: all 0.3s ease;
    font-family: var(--font-accent);
  }

  .tech-tag:hover {
    background: var(--primary);
    color: var(--bg);
  }

  @media (max-width: 1024px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .methodology {
      padding: 80px 0;
    }
    .section-header {
      margin-bottom: 3rem;
    }
    .detail-hero {
      padding: 100px 0 60px;
    }
    h1 {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }

    /* Restore Tablet Gallery Grid */
    .gallery--bento:not(.gallery--final) {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      gap: 1rem;
    }
    .gallery--bento:not(.gallery--final) .gallery__item {
      grid-area: auto !important;
      aspect-ratio: 4/3;
    }
  }

  @media (max-width: 768px) {
    /* Hero Section */
    .detail-hero {
      padding: 80px 0 60px;
    }
    .icon-box {
      width: 64px;
      height: 64px;
      margin-bottom: 1.5rem;
      border-radius: 16px;
    }
    .icon-box :global(svg) {
      width: 32px !important;
      height: 32px !important;
    }
    h1 {
      font-size: clamp(2rem, 8vw, 2.5rem);
      margin-bottom: 1.5rem;
    }
    .lead {
      font-size: 1.05rem;
    }

    /* Deep Dive */
    .deep-dive {
      padding: 40px 0;
    }
    .long-desc p {
      font-size: 1rem;
      line-height: 1.6;
    }

    /* Gallery */
    .gallery-section {
      margin: 60px 0;
    }
    .gallery--bento:not(.gallery--final) {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 1rem;
      width: 90%;
    }
    .gallery--bento:not(.gallery--final) .gallery__item {
      grid-area: auto !important;
      aspect-ratio: 16/9;
    }

    /* Methodology */
    .methodology {
      padding: 60px 0;
    }
    .process-grid {
      gap: 1.5rem;
    }
    .process-step {
      padding: 1.5rem;
      border-radius: 16px;
    }
    .step-num {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    .process-step h3 {
      font-size: 1.3rem;
    }

    /* Content & Benefits */
    .detail-content {
      padding: 60px 0;
    }
    .accent-title {
      font-size: clamp(1.8rem, 6vw, 2.2rem);
      margin-bottom: 2rem;
    }
    .content-grid {
      gap: 3rem;
    }
    .feature-list {
      gap: 1.5rem;
    }
    .feature-list li {
      font-size: 1.05rem;
      gap: 1rem;
    }
    .benefits-grid {
      gap: 1.5rem;
    }
    .benefit-card {
      padding: 1.5rem;
      border-radius: 16px;
    }
    .benefit-card p {
      font-size: 1rem;
    }

    /* Tech Stack */
    .tech-stack {
      padding: 60px 0 80px;
    }
    .tech-title {
      margin-bottom: 2rem;
    }
    .tech-tags {
      gap: 0.8rem;
    }
    .tech-tag {
      padding: 8px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(ScrollTrigger, Flip);

  function initAnimations() {
    const mm = gsap.matchMedia();

    // --- DESKTOP ANIMATIONS ---
    mm.add("(min-width: 1024px)", () => {
      // 1. Reveal Entrance for Hero (animasi langsung saat load)
      gsap.from(".detail-hero .reveal-in", {
        y: 30,
        opacity: 0,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out",
      });

      // 2. Reveal elements further down on scroll
      const scrollReveals = gsap.utils.toArray(".reveal-in");
      scrollReveals.forEach((el: any) => {
        // Lewati elemen hero karena sudah dianimasikan saat load
        if (el.closest(".detail-hero")) return;

        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
          y: 30,
          opacity: 0,
          duration: 1,
          ease: "power2.out",
        });
      });

      // Bento Flip Animation
      const galleryElement = document.querySelector("#service-gallery");
      if (galleryElement) {
        const galleryItems = galleryElement.querySelectorAll(".gallery__item");
        const galleryWrap = galleryElement.closest(".gallery-wrap");

        // Capture the final state
        galleryElement.classList.add("gallery--final");
        const flipState = Flip.getState(galleryItems);
        galleryElement.classList.remove("gallery--final");

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: galleryWrap,
            start: "center center",
            end: "+=120%",
            scrub: 1,
            pin: true,
            anticipatePin: 1,
          },
        });

        tl.add(
          Flip.to(flipState, {
            simple: true,
            ease: "power2.inOut",
          }),
        );
      }
    });

    // --- MOBILE/TABLET ANIMATIONS ---
    mm.add("(max-width: 1023px)", () => {
      // 1. Reveal Entrance for Hero
      gsap.from(".detail-hero .reveal-in", {
        y: 20,
        opacity: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: "power3.out",
      });

      // 2. Scroll reveal for content sections
      const scrollReveals = gsap.utils.toArray(".reveal-in");
      scrollReveals.forEach((el: any) => {
        if (el.closest(".detail-hero")) return;

        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
          y: 25,
          opacity: 0,
          duration: 0.8,
          ease: "power2.out",
        });
      });

      // Simple reveal for bento items on mobile
      const galleryItems = document.querySelectorAll(".gallery__item");
      if (galleryItems.length > 0) {
        gsap.from(galleryItems, {
          scrollTrigger: {
            trigger: "#service-gallery",
            start: "top 85%",
            toggleActions: "play none none reverse",
          },
          scale: 0.95,
          opacity: 0,
          duration: 0.8,
          stagger: 0.08,
          ease: "power2.out",
        });
      }
    });
  }

  if (document.readyState === "complete" || document.readyState === "interactive") {
    setTimeout(initAnimations, 300);
  } else {
    window.addEventListener("load", () => {
      setTimeout(initAnimations, 300);
    });
  }
</script>
