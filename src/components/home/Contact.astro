---
import { Mail, Phone, MapPin, Instagram, Linkedin } from 'lucide-astro';
---

<section id="contact" class="contact-section">
  <div class="container">
    <div class="contact-card reveal-contact">
      <div class="contact-grid">
        <!-- Left: Content & Info -->
        <div class="contact-info">
          <h2 class="section-title">Schedule a <span class="accent">Consultation.</span></h2>
          <p class="section-desc">Contact us to perform an initial system audit and AI-driven digital transformation in your enterprise.</p>
          
          <div class="info-list">
            <div class="info-item">
              <div class="info-icon"><Mail size={18} /></div>
              <div class="info-details">
                <span>Email</span>
                <a href="mailto:gaffy@priventry.ai">gaffy@priventry.ai</a>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon"><Phone size={18} /></div>
              <div class="info-details">
                <span>Phone</span>
                <a href="tel:+628112257586">(+62) 0811 22 57 586</a>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon"><MapPin size={18} /></div>
              <div class="info-details">
                <span>Address</span>
                <a href="https://maps.google.com/?q=Jl.+A.+Yani+No.2,+Malabar,+Kota+Bandung,+Jawa+Barat+40112" target="_blank" rel="noopener noreferrer">Jl. A. Yani No.2, Malabar, Bandung City</a>
              </div>
            </div>
          </div>

          <div class="social-links">
            <a href="https://www.instagram.com/priventry.ai" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><Instagram size={20} /></a>
            <a href="https://www.linkedin.com/company/priventry" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Linkedin size={20} /></a>
          </div>
        </div>

        <!-- Right: Minimalist Form -->
        <div class="contact-form-container">
          <form class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <input type="text" id="name" required placeholder=" " />
                <label for="name">Name</label>
                <div class="input-line"></div>
              </div>
              <div class="form-group">
                <input type="email" id="email" required placeholder=" " />
                <label for="email">Email</label>
                <div class="input-line"></div>
              </div>
            </div>
            
            <div class="form-group">
              <input type="text" id="subject" required placeholder=" " />
              <label for="subject">Project Type</label>
              <div class="input-line"></div>
            </div>

            <div class="form-group">
              <textarea id="message" rows="3" required placeholder=" "></textarea>
              <label for="message">Your Message</label>
              <div class="input-line"></div>
            </div>

            <div class="form-footer">
              <button type="submit" class="submit-btn">
                <span>Send Message</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: var(--section-spacing) 0;
    background-color: var(--bg);
    position: relative;
    overflow: hidden;
    border-top: 1px dashed rgba(255, 255, 255, 0.15); /* Garis pembatas atas */
  }

  .contact-card {
    background-color: #0d0d0d;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: clamp(20px, 5vw, 40px);
    padding: clamp(2rem, 8vw, 5rem);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.4);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(3rem, 10vw, 6rem);
    align-items: start;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
    letter-spacing: -2px;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 400px;
    margin-bottom: 3rem;
    line-height: 1.6;
    font-weight: 300;
  }

  /* Info Items */
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .info-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .info-icon {
    width: 44px;
    height: 44px;
    background: rgba(252, 159, 33, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
  }

  .info-details span {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }

  .info-details a, .info-details p {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text);
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .social-links a {
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .social-links a:hover {
    color: var(--primary);
    transform: translateY(-5px);
  }

  /* Minimalist Form Styles */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .form-group {
    position: relative;
    margin-bottom: 3.5rem;
  }

  .form-group input, 
  .form-group textarea {
    width: 100%;
    background: transparent;
    border: none;
    padding: 1rem 0;
    color: var(--text);
    font-size: 1.1rem;
    font-family: inherit;
    outline: none;
  }

  .form-group label {
    position: absolute;
    top: 1rem;
    left: 0;
    color: var(--text-muted);
    font-size: 1.1rem;
    pointer-events: none;
    transition: 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .input-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    transition: 0.3s ease;
  }

  /* Label Floating Logic */
  .form-group input:focus ~ label,
  .form-group input:not(:placeholder-shown) ~ label,
  .form-group textarea:focus ~ label,
  .form-group textarea:not(:placeholder-shown) ~ label {
    top: -1.5rem;
    font-size: 0.85rem;
    color: var(--primary);
    letter-spacing: 1px;
  }

  .form-group input:focus ~ .input-line,
  .form-group textarea:focus ~ .input-line {
    background: var(--primary);
    height: 2px;
    box-shadow: 0 0 15px rgba(252, 159, 33, 0.3);
  }

  /* Submit Button */
  .submit-btn {
    position: relative;
    background-color: var(--primary);
    color: #000;
    border: none;
    padding: 1.2rem 3rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 100px;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .submit-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(252, 159, 33, 0.2);
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .section-title {
      letter-spacing: -1px;
      text-align: left;
    }
    .section-desc {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .form-group {
      margin-bottom: 2.5rem;
    }
    .submit-btn {
      width: 100%;
      padding: 1.2rem 2rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initContactAnimation = () => {
    const reveals = document.querySelectorAll('.reveal-contact');
    
    gsap.from(reveals, {
      scrollTrigger: {
        trigger: '.contact-section',
        start: 'top 70%',
        toggleActions: 'play none none reverse'
      },
      y: 50,
      opacity: 0,
      duration: 1,
      stagger: 0.1,
      ease: 'power3.out'
    });
  };

  window.addEventListener('load', initContactAnimation);
</script>
