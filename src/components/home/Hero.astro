---

---

<section class="hero-comparison">
  <div class="panel">
    <div class="hero-content">
      <h1 class="hero-title">
        Unified Agentic AI Platform for <span class="accent"
          >Enterprise Automation</span
        >
      </h1>
      <div class="hero-scroll-indicator">
        <div class="mouse-icon">
          <div class="wheel"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="comparisonSection">
    <div class="comparisonImage beforeImage">
      <img src="/images/hero_legacy.png" alt="Before: Legacy Infrastructure" />
      <div class="overlay-text before-text">LEGACY</div>
    </div>
    <div class="comparisonImage afterImage">
      <img src="/images/hero_autonomous.png" alt="After: Autonomous AI" />
      <div class="overlay-text after-text">AUTONOMOUS</div>
    </div>
  </section>
</section>

<style>
  .hero-comparison {
    background-color: var(--bg);
  }

  .panel {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding-top: var(--nav-height);
  }

  .hero-content {
    perspective: 1000px;
    z-index: 10;
  }

  .hero-title {
    font-family: var(--font-slabo);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 1.1;
    margin-bottom: 2rem;
    visibility: hidden; /* Prevent FOUC */
  }

  .hero-title .line {
    overflow: visible !important;
  }

  .hero-title .accent {
    color: var(--primary);
  }

  .hero-scroll-indicator {
    opacity: 0.6;
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .mouse-icon {
    width: 26px;
    height: 42px;
    border: 2px solid var(--text-muted);
    border-radius: 20px;
    position: relative;
  }

  .mouse-icon .wheel {
    width: 4px;
    height: 8px;
    background: var(--primary);
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollWheel 2s infinite ease-in-out;
  }

  @keyframes scrollWheel {
    0% {
      top: 6px;
      opacity: 1;
    }
    50% {
      top: 18px;
      opacity: 0;
    }
    100% {
      top: 6px;
      opacity: 0;
    }
  }

  .comparisonSection {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .comparisonImage {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .comparisonImage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    filter: brightness(0.6);
  }

  /* Central Overlay Text */
  .overlay-text {
    position: relative;
    z-index: 5;
    font-size: clamp(3rem, 12vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    pointer-events: none;
    line-height: 1;
    text-align: center;
  }

  .before-text {
    color: rgba(255, 255, 255, 0.1);
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);
    text-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
  }

  .after-text {
    color: var(--primary);
    text-shadow: 0 0 80px rgba(252, 159, 33, 0.5);
    filter: drop-shadow(0 0 10px var(--primary));
    font-family: var(--font-accent);
    font-weight: 600;
  }

  .afterImage {
    position: absolute;
    overflow: hidden;
    top: 0;
    width: 100%;
    transform: translate(100%, 0px);
    z-index: 2;
  }

  .afterImage img {
    transform: translate(-100%, 0px);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: clamp(2rem, 10vw, 3.2rem);
      padding: 0 var(--container-padding);
      line-height: 1.25;
      margin-bottom: 3rem;
    }

    .overlay-text {
      font-size: clamp(2rem, 11vw, 5rem);
      letter-spacing: 0.01em;
    }

    .panel {
      min-height: 100vh;
      padding-top: 100px;
    }

    .comparisonSection {
      height: 70vh;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  gsap.registerPlugin(ScrollTrigger);

  const initHeroAnimation = () => {
    // Reveal title once script loads
    const title: HTMLElement | null = document.querySelector(".hero-title");
    if (title) title.style.visibility = "visible";

    // Split text into lines
    const text = new SplitType(".hero-title", {
      types: "lines,words,chars",
      lineClass: "split-line",
      wordClass: "split-word",
      charClass: "split-char",
    });

    // Headline Entry Animation (Looping Typing effect)
    const entryTl = gsap.timeline({
      repeat: -1,
      repeatDelay: 2,
    });

    if (text.chars && text.chars.length > 0) {
      entryTl
        .from(text.chars, {
          opacity: 0,
          y: 10,
          duration: 0.05,
          stagger: {
            each: 0.03,
            ease: "none",
          },
          ease: "power2.inOut",
        })
        .to(text.chars, {
          opacity: 0,
          y: -10,
          duration: 0.5,
          stagger: {
            each: 0.02,
            from: "end",
          },
          ease: "power2.in",
          delay: 3,
        });
    }

    entryTl.from(
      ".hero-scroll-indicator",
      {
        opacity: 0,
        y: 20,
        duration: 1,
        ease: "power3.out",
      },
      "-=1",
    );

    // Comparison logic
    gsap.utils.toArray(".comparisonSection").forEach((section: any) => {
      let tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "center center",
          end: () => "+=" + section.offsetWidth,
          scrub: true,
          pin: true,
          anticipatePin: 1,
          refreshPriority: 10,
        },
        defaults: { ease: "none" },
      });

      // Force initial state to prevent clumped text
      gsap.set(section.querySelector(".afterImage"), { xPercent: 100 });
      gsap.set(section.querySelector(".afterImage img"), { xPercent: -100 });

      tl.fromTo(
        section.querySelector(".afterImage"),
        { xPercent: 100, x: 0 },
        { xPercent: 0 },
      )
        .fromTo(
          section.querySelector(".afterImage img"),
          { xPercent: -100, x: 0 },
          { xPercent: 0 },
          0,
        )
        // Slightly animate the text reveal for extra polish
        .fromTo(
          section.querySelector(".after-text"),
          { opacity: 0, scale: 0.8 },
          { opacity: 1, scale: 1 },
          0.2,
        );
    });
  };

  // Run immediately if preloader was already completed or skipped
  if (sessionStorage.getItem("compro_visited")) {
    initHeroAnimation();
  } else {
    // Listen for the custom event dispatched by Preloader.astro
    window.addEventListener("preloaderComplete", initHeroAnimation);
  }

  // Fallback: If preloader logic fails or isn't loaded (e.g. subpages), run after 3s
  setTimeout(() => {
    const title = document.querySelector(".hero-title");
    if (title && getComputedStyle(title).visibility === "hidden") {
      initHeroAnimation();
    }
  }, 3000);
</script>
